# Family Accounting 环境变量配置
# 复制为 .env 后按需修改

# 服务器
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=true

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# 数据目录（默认 data/）
DATA_DIR=data

# 账单目录（xlsx 截图源文件存放目录，默认 data/bills）
BILL_DIR=data/bills

# 人员配置（逗号分隔）
PERSONS=BB,LN
PERSON_LABELS={"BB":"斌","LN":"纳"}

# 上传文件大小限制（字节，默认 16MB）
MAX_CONTENT_LENGTH=16777216
